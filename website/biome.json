{
	"$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
	"root": false,
	"files": {
		"ignoreUnknown": true,
		"includes": [
			"**",
			"!dist",
			"!.astro",
			"!.wrangler",
			"!node_modules"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"html": {
		"experimentalFullSupportEnabled": true,
		"formatter": {
			"enabled": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"semicolons": "always",
			"trailingCommas": "all"
		}
	}
}