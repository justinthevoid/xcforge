---
import type { WorkflowsJourneysSectionCopy } from '../../data/homepage';

type Props = {
	section: WorkflowsJourneysSectionCopy;
};
// biome-ignore lint/correctness/noUnusedVariables: Astro template references section.
const { section } = Astro.props;
---

<section
  id="workflows"
  class="narrative-section narrative-workflows"
  aria-labelledby="workflows-title"
>
  <div class="narrative-shell">
    <h2 id="workflows-title">{section.heading}</h2>
    <p class="narrative-purpose">{section.purpose}</p>
    <ol class="journey-list" aria-label="Workflow journeys">
      {
        section.journeys.map((journey) => (
          <li>
            <h3>{journey.title}</h3>
            <p>{journey.detail}</p>
              <p class="journey-outcome">
                <span class="journey-outcome-label">Outcome:</span> {journey.outcome}
              </p>
              {
                journey.artifact.status === "available" ? (
                  <p class="journey-artifact">
                    <span class="journey-artifact-label">Artifact:</span>{" "}
                    <a
                      class="journey-artifact-link"
                      href={journey.artifact.href}
                      target={journey.artifact.external ? "_blank" : undefined}
                      rel={journey.artifact.external ? "noopener noreferrer" : undefined}
                    >
                      {journey.artifact.label}
                    </a>
                    <span class="journey-artifact-summary">{journey.artifact.summary}</span>
                  </p>
                ) : (
                  <p class="journey-artifact-unavailable" role="status">
                    <span class="journey-artifact-state">Unavailable</span>
                    {journey.artifact.unavailableMessage}
                  </p>
                )
              }
          </li>
        ))
      }
    </ol>
  </div>
</section>
