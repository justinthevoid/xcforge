---
import {
	type HeroCopy,
	resolveApprovedTrustClaimForRender,
	resolveProofSnapshotForRender,
	resolveProvenanceFallbackHrefForRender,
} from '../../data/homepage';
import ProofToggle from './ProofToggle.svelte';

type Props = {
	hero: HeroCopy;
	useFallback: boolean;
};

const { hero, useFallback } = Astro.props;

const safeFallbackDocsHref = resolveProvenanceFallbackHrefForRender(
	hero.provenanceUnavailableDocsHref,
);

const resolvedProofClaims = useFallback
	? []
	: hero.proofClaims.map((claim) =>
			resolveApprovedTrustClaimForRender(claim, safeFallbackDocsHref),
		);
const resolvedProofSnapshots = useFallback
	? []
	: hero.proofSnapshots.map((snapshot) =>
			resolveProofSnapshotForRender(snapshot, safeFallbackDocsHref),
		);

function isExternalHref(href: string): boolean {
	return /^https?:\/\//i.test(href);
}
---

<section id="product" class="hero-proof" aria-labelledby="hero-title">
	<div class="hero-copy">
		<p class="hero-kicker">For AI-assisted iOS developers</p>
		<h1 id="hero-title">{hero.problemLine}</h1>
		<p class="hero-role">{hero.productRole}</p>

		<section
			id="install-section"
			class="hero-actions"
			role="group"
			aria-label="Install primary action with supporting depth links"
		>
			<p id="hero-supporting-path-note" class="sr-only">
				Docs and Workflow Guide help evaluate install readiness and remain supporting actions.
			</p>
			<a
				class="cta-primary install-intent-trigger"
				href={hero.installHref}
				target={hero.installExternal ? "_blank" : undefined}
				rel={hero.installExternal ? "noreferrer noopener" : undefined}
				data-action-tier="primary"
				data-install-intent-trigger="true"
				data-install-intent-source="hero"
				data-install-command={hero.installCommand}
				data-install-target="homebrew"
			>
				Install via Homebrew
			</a>
			<a
				class="cta-secondary cta-supporting-path"
				href="/docs"
				data-action-tier="secondary"
				data-supporting-path="true"
				aria-describedby="hero-supporting-path-note"
			>
				Docs
			</a>
			<a
				class="cta-secondary cta-supporting-path"
				href="/docs/getting-started/"
				data-action-tier="secondary"
				data-supporting-path="true"
				aria-describedby="hero-supporting-path-note"
			>
				Workflow Guide
			</a>
		</section>

		<p class="install-command">
			<span>Run:</span>
			<code>{hero.installCommand}</code>
		</p>
	</div>

	<aside class="proof-panel" aria-live="polite">
		<h2>Technical proof</h2>
		{useFallback ? (
				<>
					<p>{hero.fallbackProofText}</p>
					<p>
						Use <a href="/docs">Docs</a>,
						<a
							href="https://github.com/justinthevoid/xcforge/blob/main/CHANGELOG.md"
							target="_blank"
							rel="noreferrer noopener"
						>
							Changelog
						</a>
						, and
						<a href={safeFallbackDocsHref}>provenance guidance</a>
						for source-backed detail.
					</p>
				</>
			) : (
				<>
					<p class="proof-headline">{hero.proofHeadline}</p>
					<ul class="hero-proof-strip" aria-label="Approved trust claims">
						{resolvedProofClaims.map((claim) => (
							<li class="proof-claim-chip">
								<details class="proof-marker">
									<summary class="proof-marker-summary">
										<span>{claim.text}</span>
										<span
											class="proof-marker-state"
											data-state={claim.provenance.state}
										>
											{claim.provenance.stateLabel}
										</span>
									</summary>
									<p class="proof-marker-detail">
										{claim.provenance.stateDetail}
									</p>
									{claim.provenance.sources.length > 0 ? (
										<ul class="proof-marker-sources">
											{claim.provenance.sources.map((source) => (
												<li>
													<a
														href={source.href}
														target={
															isExternalHref(source.href) ? "_blank" : undefined
														}
														rel={
															isExternalHref(source.href)
																? "noreferrer noopener"
																: undefined
														}
													>
														{source.label}
													</a>
													<span class="proof-marker-source-meta">
														{source.capturedOnLabel} · {source.freshnessLabel}
													</span>
												</li>
											))}
										</ul>
									) : null}
									{claim.provenance.state === "warning" ? (
										<p class="proof-marker-warning">
											{claim.provenance.sources.length > 0
												? "Some provenance entries are unavailable."
												: "Provenance details are unavailable."}
											<a href={claim.provenance.fallbackHref}>
												{" "}
												Read provenance guidance.
											</a>
										</p>
									) : null}
								</details>
							</li>
						))}
					</ul>
					<p class="proof-strip-note">
						Capability scope only. This proof strip avoids benchmark or
						superlative claims.
					</p>
					<ProofToggle
						snapshots={resolvedProofSnapshots}
						defaultSnapshotId={hero.defaultProofSnapshotId}
						client:load
					/>
				</>
			)}
	</aside>
</section>
