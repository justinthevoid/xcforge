---
import type { NavItem, NavItemId } from '../../data/homepage';

type Props = {
	navItems: NavItem[];
};

const { navItems } = Astro.props;

const supportingSecondaryNavIds = new Set<NavItemId>([
	'docs',
	'workflow-guide',
	'changelog',
	'github',
]);

type NavAnalyticsConfig = {
	eventName:
		| 'homepage.install.cta.clicked'
		| 'homepage.docs.clicked'
		| 'homepage.workflow-guide.clicked'
		| 'homepage.github.outbound.clicked';
	intentSignal: 'install' | 'depth-navigation';
	destination: 'install' | 'docs' | 'workflow-guide' | 'github';
};

const navAnalyticsById: Partial<Record<NavItemId, NavAnalyticsConfig>> = {
	install: {
		eventName: 'homepage.install.cta.clicked',
		intentSignal: 'install',
		destination: 'install',
	},
	docs: {
		eventName: 'homepage.docs.clicked',
		intentSignal: 'depth-navigation',
		destination: 'docs',
	},
	'workflow-guide': {
		eventName: 'homepage.workflow-guide.clicked',
		intentSignal: 'depth-navigation',
		destination: 'workflow-guide',
	},
	github: {
		eventName: 'homepage.github.outbound.clicked',
		intentSignal: 'depth-navigation',
		destination: 'github',
	},
};
---

<header class="site-header">
	<nav class="global-nav" aria-label="Primary">
		<a class="brand" href="/" aria-label="xcforge homepage"> xcforge </a>
		<p id="global-nav-support-note" class="sr-only">
			Install is the primary action. Docs, Workflow Guide, Changelog, and GitHub are supporting
			depth paths.
		</p>
		<ul class="nav-list">
			{navItems.map((item) => {
          const isInstall = item.id === "install";
          const isSupportingSecondary = supportingSecondaryNavIds.has(item.id);
          const analyticsConfig = navAnalyticsById[item.id];

          return (
            <li>
              <a
                class={isInstall ? "nav-link nav-link-install" : "nav-link"}
                href={item.href}
                target={item.external ? "_blank" : undefined}
                rel={item.external ? "noreferrer noopener" : undefined}
                data-action-tier={isInstall ? "primary" : "secondary"}
                data-supporting-path={
                  isSupportingSecondary ? "true" : undefined
                }
                data-analytics-event-name={analyticsConfig?.eventName}
                data-analytics-intent-signal={analyticsConfig?.intentSignal}
                data-analytics-destination={analyticsConfig?.destination}
                data-analytics-source-surface={
                  analyticsConfig ? "global-nav" : undefined
                }
                aria-describedby={
                  isSupportingSecondary ? "global-nav-support-note" : undefined
                }
              >
                {item.label}
              </a>
            </li>
          );
        })}
		</ul>
	</nav>
</header>
