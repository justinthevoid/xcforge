---
import type { FinalCtaCopy } from '../../data/homepage';
import ActionLink from '../primitives/ActionLink.astro';
import SectionBlock from '../primitives/SectionBlock.astro';

type Props = {
	finalCta: FinalCtaCopy;
};

const { finalCta } = Astro.props;
---

<SectionBlock id="final-cta" className="final-cta" labelledBy="final-cta-title">
	<div class="final-cta-shell">
		<h2 id="final-cta-title">{finalCta.heading}</h2>
		<p class="final-cta-summary">{finalCta.summary}</p>

		<div class="final-cta-install-block">
			<pre class="final-cta-command" data-copy-source tabindex="0" aria-label="Install command">{finalCta.installCommand}</pre>
			<button class="copy-command" type="button" data-copy-adjacent>
				{finalCta.handoffCopyButtonLabel}
			</button>
		</div>

		<div
			class="final-cta-actions"
			role="group"
			aria-label="Final install action"
		>
			<ActionLink
				tier="primary"
				className="install-intent-trigger"
				href={finalCta.installHref}
				label={finalCta.installLabel}
				external={finalCta.installExternal}
				installIntentTrigger={true}
				installIntentSource="final-cta"
				installCommand={finalCta.installCommand}
				installTarget="homebrew"
				data-analytics-event-name="homepage.install.cta.clicked"
				data-analytics-intent-signal="install"
				data-analytics-destination="install"
				data-analytics-source-surface="final-cta"
			/>
			<ActionLink
				tier="secondary"
				href={finalCta.docsHref}
				label={finalCta.docsLabel}
				data-analytics-event-name="homepage.docs.clicked"
				data-analytics-intent-signal="depth-navigation"
				data-analytics-destination="docs"
				data-analytics-source-surface="final-cta"
			/>
		</div>

		<section
			class="install-handoff"
			data-install-handoff
			data-ready-message={finalCta.handoffReadyMessage}
			data-failure-message={finalCta.handoffFailureMessage}
			data-restored-message={finalCta.handoffRestoredMessage}
			hidden
			aria-live="polite"
		>
			<h3>{finalCta.handoffTitle}</h3>
			<p
				class="install-handoff-message"
				data-install-handoff-message
				role="status"
				aria-atomic="true"
			>
				{finalCta.handoffReadyMessage}
			</p>
			<div class="install-handoff-command-row">
				<pre
					class="install-handoff-command"
					data-install-handoff-command
					tabindex="0"
					aria-label="Install command"
				>{finalCta.installCommand}</pre>
				<button class="copy-command" type="button" data-copy-install-command>
					{finalCta.handoffCopyButtonLabel}
				</button>
			</div>
			<a
				class="install-handoff-link"
				data-install-handoff-guide-link
				href={finalCta.installHref}
				target={finalCta.installExternal ? "_blank" : undefined}
				rel={finalCta.installExternal ? "noreferrer noopener" : undefined}
			>
				{finalCta.handoffGuideLabel}
			</a>
		</section>
	</div>
</SectionBlock>
